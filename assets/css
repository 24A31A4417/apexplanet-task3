body{
    background:#f4f6f9;
    font-family:'Segoe UI',sans-serif;
}

.navbar{
    box-shadow:0 2px 10px rgba(0,0,0,.15);
}

.card{
    border:none;
    border-radius:15px;
    transition:.3s;
}

.card:hover{
    transform:translateY(-4px);
}

.card-body{
    padding:25px;
}

.btn{
    border-radius:8px;
}

.page-link{
    border-radius:6px;
    margin:0 3px;
}

h2{
    font-weight:700;
}